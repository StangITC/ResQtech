# ResQTech System - Git Ignore

# Logs
logs/*.log
*.log
*.txt
!logs/.gitkeep
!logs/.htaccess
logs/*.json
logs/*.jsonl

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Backup files
*.bak
*.backup
*.old
*.tmp

# Dependencies (if using composer)
/vendor/

# Cache
*.cache

# Sensitive files
config/config.local.php

# Keys / certificates / signing
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*.der
mobile_app/android/key.properties
mobile_app/android/**/key.properties
mobile_app/android/**/upload-keystore.jks
mobile_app/android/**/upload-keystore.keystore

# Firebase / Apple service configs
**/google-services.json
**/GoogleService-Info.plist
**/*.mobileprovision

# Flutter (mobile_app)
mobile_app/.dart_tool/
mobile_app/build/
mobile_app/android/local.properties
